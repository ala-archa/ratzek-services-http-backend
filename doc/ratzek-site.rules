# Canonical copy of the host-direct Prometheus rules deployed to
# /etc/prometheus/rules/ratzek-site.rules (ansible is outdated; managed by hand).
# Thresholds calibrated against 7-day Prometheus history. See doc/alerting-runbook.md.
groups:
  - name: ratzek-site
    rules:
      - alert: RatzekBatteryDeepDischarge
        expr: daly_bms_pack_voltage_volts * daly_bms_current_amperes < -150
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Глубокий разряд АКБ: {{ $value | humanize }} Вт"

      - alert: RatzekSolarNotChargingDaytime
        # Реальный фолт = днём (min lux[6h]>100 — свет весь 6ч, исключает рассвет), заряда нет
        # (max current[6h]<0.5) И SOC ПАДАЕТ (>2%/6ч). Условие на падение SOC отсекает «батарея
        # полна» (на плато SOC ровный → ток 0 нормой; временный MPPT заряжает лишь до ~85%) — не
        # зависит от лимита контроллера, ловит именно «батарея разряжается при свете».
        expr: min_over_time(veml7700_lux[6h]) > 100 and on() (max_over_time(daly_bms_current_amperes[6h]) < 0.5 and (daly_bms_soc_percent < (daly_bms_soc_percent offset 6h) - 2))
        for: 15m
        labels: { severity: warning }
        annotations:
          summary: "Днём заряда АКБ нет уже 6ч (свет есть) — проверить панели/контроллер заряда"

      - alert: RatzekBatterySOCLow
        expr: daly_bms_soc_percent < 35
        for: 15m
        labels: { severity: warning }
        annotations:
          summary: "Заряд АКБ низкий: {{ $value | humanize }}%"

      - alert: RatzekBatterySOCCritical
        expr: daly_bms_soc_percent < 20
        for: 5m
        labels: { severity: critical }
        annotations:
          summary: "Заряд АКБ КРИТИЧЕСКИЙ: {{ $value | humanize }}% — скоро полное отключение"

      - alert: RatzekBatteryVoltageLow
        expr: daly_bms_pack_voltage_volts < 22.5
        for: 10m
        labels: { severity: critical }
        annotations:
          summary: "Напряжение АКБ {{ $value | humanize }} В — пустая батарея / близко отсечка"

      - alert: RatzekBMSAlarm
        expr: daly_bms_alarm != 0
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Сработала защита BMS: {{ $labels.type }}"

      - alert: RatzekBMSCommsLost
        expr: time() - daly_bms_last_frame_timestamp_seconds > 300
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Нет телеметрии BMS уже {{ $value | humanize }}с — слепы по питанию"

      - alert: RatzekPoEPortDown
        # group_left(comment): poe_current не несёт подпись порта — подтягиваем её из _running
        # (max without(...) схлопывает волатильный running и лишние лейблы, оставляя comment).
        expr: (mikrotik_poe_current == 0) * on(name, interface) group_left(comment) (max without(running, disabled, slave, type, address, instance, job) (mikrotik_interface_running))
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "PoE-порт без питания: {{ $labels.name }} {{ $labels.interface }} «{{ $labels.comment }}»"

      - alert: RatzekMikrotikUnreachable
        expr: mikrotik_scrape_collector_success == 0
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "MikroTik недоступен для опроса: {{ $labels.name }}"

      - alert: RatzekWANDown
        expr: ratzek_internet_available == 0
        for: 10m
        labels: { severity: critical }
        annotations:
          summary: "Нет интернета (WAN down) — аплинк недоступен"

      - alert: RatzekAlertingDegraded
        expr: rate(alertmanager_notifications_failed_total[10m]) > 0 or rate(ratzek_alert_webhook_errors_total[15m]) > 0 or ratzek_telegram_queue_len > 20
        for: 10m
        labels: { severity: warning }
        annotations:
          summary: "Деградация доставки алертов (очередь/ошибки webhook/AM notif-fail)"

      # --- Tier 2 (added 2026-07-10) ---
      - alert: RatzekLTEFlapping
        expr: resets(mikrotik_lte_interface_session_uptime[1h]) > 3
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "LTE часто переподключается: {{ $value | humanize }} реконнектов/час ({{ $labels.name }})"

      - alert: RatzekDeviceMetricsStalled
        expr: ratzek_device_metrics_age_seconds > 1800
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Сэмплер device-metrics завис: {{ $value | humanize }}с без обновления"

      - alert: RatzekPiTempHigh
        expr: node_hwmon_temp_celsius > 75
        for: 10m
        labels: { severity: warning }
        annotations:
          summary: "Температура Pi {{ $value | humanize }}°C — близко к троттлингу"

      - alert: RatzekBMSChargingCold
        expr: daly_bms_temperature_min_celsius < 1 and on(instance) daly_bms_current_amperes > 1
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Заряд АКБ при {{ $value | humanize }}°C — заряд LFP на морозе повреждает ячейки"

      - alert: RatzekACLMassDrop
        expr: delta(ratzek_clients_in_acl[15m]) < -30
        for: 1m
        labels: { severity: warning }
        annotations:
          summary: "Резкий обвал клиентов в acl: {{ $value | humanize }} за 15м (массовый дисконнект?)"

      - alert: RatzekMikrotikLinkFlapping
        # только ether: WiFi (wlan*) флапает по природе (до 17/ч) — не про «линк»; ethernet <~1/ч.
        # max without(running,...): у порта 2 серии по волатильному running — схлопываем, сохраняя comment.
        expr: max without(running, disabled, slave, type) (increase(mikrotik_interface_link_downs{interface=~"ether.*"}[1h])) > 5
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Флап линка MikroTik: {{ $value | humanize }} падений/час ({{ $labels.name }} {{ $labels.interface }} «{{ $labels.comment }}»)"

      - alert: RatzekISPBalanceCritical
        expr: ratzek_isp_balance < 200
        for: 15m
        labels: { severity: critical }
        annotations:
          summary: "Баланс SIM критический: {{ $value | humanize }} — скоро отключат"

      # --- Tier 3 (added 2026-07-10) ---
      # RatzekWebcamStale requires the textfile metric ratzek_webcam_last_image_timestamp,
      # produced by doc/webcam-freshness-metric.sh (cron */5, node_exporter textfile collector).
      - alert: RatzekWebcamStale
        expr: time() - ratzek_webcam_last_image_timestamp > 1200
        for: 15m
        labels: { severity: warning }
        annotations:
          summary: "Камера не обновляет снимок уже {{ $value | humanize }}с (зависла / нет непустых кадров)"

      - alert: RatzekBMSCellImbalance
        expr: daly_bms_cell_voltage_delta_volts > 0.2
        for: 30m
        labels: { severity: warning }
        annotations:
          summary: "Разбаланс ячеек АКБ: разброс {{ $value | humanize }} В (слабая/деградирующая ячейка)"

      - alert: RatzekMikrotikHighCPU
        expr: mikrotik_system_cpu_load > 90
        for: 15m
        labels: { severity: warning }
        annotations:
          summary: "MikroTik CPU {{ $value | humanize }}% ({{ $labels.name }})"

      - alert: RatzekMikrotikLowMemory
        expr: mikrotik_system_free_memory / mikrotik_system_total_memory < 0.08
        for: 15m
        labels: { severity: warning }
        annotations:
          summary: "MikroTik мало памяти: {{ $value | humanizePercentage }} свободно ({{ $labels.name }})"
